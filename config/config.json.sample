{
	"debug": false,
	"loglevel": "INFO",
	"live_mode": true,
	"preferences": {
		"time_format": "12h",
		"end_of_day": "8:00",
		"location": "",
		"live_game_refresh_rate": 10,
		"teams": [
			"Maple Leafs", "Predators", "Stars","Canucks"
		],
		"sog_display_frequency": 4,
		"goal_animations": {
        	"pref_team_only": true
    	},
		"disable_penalty_animation": false,
		"show_power_play_details": false
	},

	"states":{
		"off_day": [
			"standings",
			"team_summary",
			"clock"
		],
		"scheduled": [
			"team_summary",
			"scoreticker",
			"standings",
			"clock"
		],
		"intermission": [
			"scoreticker",
			"standings",
			"team_summary"
		],
		"post_game": [
			"team_summary",
			"scoreticker",
			"standings",
			"clock"
		],
		"post_season_active": [],
		"post_season_eliminated": [],
		"off_season": []
	},

	"boards": {
		"scoreticker": {
			"preferred_teams_only": false,
			"rotation_rate": 5
		},
        "seriesticker": {
            "preferred_teams_only": true,
            "rotation_rate": 5,
			"hide_completed_rounds": false
        },
		"standings": {
			"preferred_standings_only": true,
			"standing_type": "division",
			"divisions": "atlantic",
			"conference": "eastern",
			"wildcard_limit": 4,
			"large_font": false
		},
		"clock": {
			"duration": 15,
			"hide_indicator": false,
			"preferred_team_colors": true,
            "clock_rgb": "",
            "date_rgb": "",
            "flash_seconds": true
		},
		"weather": {
			"enabled": false,
			"view": "full",
			"units": "metric",
			"duration": 60,
			"data_feed": "EC",
			"owm_apikey": "",
			"update_freq": 5,
			"show_on_clock": true,
			"forecast_enabled": false,
			"forecast_show_today": false,
			"forecast_days": 3,
			"forecast_update": 1
		},
        "wxalert": {
            "alert_feed": "EC",
            "update_freq": 5,
            "show_alerts": false,
        	"nws_show_expire": false,
            "alert_title": true,
            "scroll_alert": true,
            "alert_duration": 5,
			"show_on_clock": true
		},
		"player_stats": {
			"rotation_rate": 7,
			"players": [
				"8471214",
				"8480313",
				"8471675",
				"8478402"
			]
		},
		"stats_leaders": {
			"rotation_rate": 5,
			"categories": [
				"goals",
				"assists",
				"points"
			],
			"use_large_font": false,
			"scroll_speed": 0.2,
			"limit": 10
		},
		"draft_tracker": {
			"rotation_rate": 6,
			"picks_to_show": 5,
			"highlight_preferred": true,
			"update_freq_minutes": 5
		},
		"awards": {
			"rotation_rate": 6,
			"trophy_set": "major",
			"update_freq_hours": 24
		},
		"free_agency": {
			"rotation_rate": 6,
			"mode": "signings",
			"max_entries": 10,
			"preferred_teams_only": false,
			"update_freq_minutes": 60
		},
		"team_news": {
			"rotation_rate": 12,
			"max_items": 5,
			"update_freq": 30
		},
		"holiday": {
			"country": "us",
			"skip_non_holidays": true,
			"non_holiday_message": "HAVE A GREAT DAY",
			"duration": 8
		}
	},
	"sbio": {
		"mqtt": {
            "enabled": false,
            "broker": "test.mosquitto.org",
            "port": 1883,
			"auth": {
				"username": "",
				"password": ""
			},
	        "main_topic": "scoreboard"
        },
		"screensaver": {
            "enabled": false,
			"animations": true,
            "start": "22:00",
            "stop": "08:00",
            "data_updates": false,
			"motionsensor": false,
            "pin": 7,
            "delay": 30
        },
		"dimmer": {
			"enabled": false,
			"source": "software",
			"daytime": "",
            "nighttime": "",
            "offset": 0,
			"frequency": 5,
			"light_level_lux": 400,
			"mode": "always",
			"sunset_brightness": 5,
			"sunrise_brightness": 40
		},
		"pushbutton": {
			"enabled": false,
			"bonnet": false,
			"pin": 25,
			"reboot_duration": 2,
			"reboot_override_process": "",
			"display_reboot": true,
			"poweroff_duration": 10,
			"poweroff_override_process": "",
			"display_halt": true,
			"state_triggered1": "weather",
			"state_triggered1_process": ""
		}
	}
}
